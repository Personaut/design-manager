# ─── OpenClaw Bot Configuration ──────────────────────────────
# Copy this to .env and fill in real values

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Jira
JIRA_BASE_URL=https://personaut.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=DEV
JIRA_POLL_LABEL=dev-agent
JIRA_POLL_INTERVAL_MINUTES=5

# AWS SQS
AWS_REGION=us-east-1
TASK_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/013249835487/dev-tasks-queue
RESULT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/013249835487/dev-results-queue

# GitHub
GITHUB_DEFAULT_REPO=https://github.com/Personaut/test-repository

# Server
PORT=3000
